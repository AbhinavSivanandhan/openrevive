APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_DB=openrevive
POSTGRES_USER=openrevive
POSTGRES_PASSWORD=openrevive_local_password

DATABASE_URL=postgresql+asyncpg://openrevive:openrevive_local_password@localhost:5432/openrevive
DATABASE_SYNC_URL=postgresql+psycopg://openrevive:openrevive_local_password@localhost:5432/openrevive

REDIS_URL=redis://localhost:6379/0

MINIO_ROOT_USER=openrevive_minio
MINIO_ROOT_PASSWORD=openrevive_minio_local_password
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=openrevive_minio
S3_SECRET_KEY=openrevive_minio_local_password
S3_BUCKET=openrevive-local

PROCESSING_ENABLED=true
AGENT_ENABLED=true
AGENT_WRITES_ENABLED=false

MAX_FILES_PER_IMPORT=100
MAX_FILE_SIZE_MB=25
MAX_CONCURRENT_JOBS=2
MAX_RETRIES=3
